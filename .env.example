# ─── Database ────────────────────────────────────────────────────────────────
# Docker PostgreSQL (port 5453 to avoid conflict with any local postgres)
DATABASE_URL=postgresql://pipeline:pipepipe@localhost:5453/iot_research

# ─── Honeypot log paths (rsync'd from VPS) ───────────────────────────────────
COWRIE_LOG_PATH=/data/raw-logs/cowrie/cowrie.json
OPENCANARY_LOG_PATH=/data/raw-logs/opencanary/opencanary.log

# ─── Pipeline internals ──────────────────────────────────────────────────────
# Where pipeline writes its own logs
PIPELINE_LOG_DIR=/tmp/iot-pipeline/logs
# Where byte-offset bookmarks are stored between runs
PIPELINE_STATE_DIR=/tmp/iot-pipeline/state

# ─── External API keys (Phase 2) ─────────────────────────────────────────────
SHODAN_API_KEY=your_shodan_api_key_here
CENSYS_API_ID=your_censys_api_id_here
CENSYS_API_SECRET=your_censys_api_secret_here
